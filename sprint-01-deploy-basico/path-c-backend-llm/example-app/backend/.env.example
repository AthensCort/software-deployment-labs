# Variables del BACKEND — nunca van al frontend
# Copiar como .env y rellenar con valores reales

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# LLM — usar el que corresponda a tu proyecto
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Servidor
PORT=3001
# URL del frontend (para CORS) — cambiar en producción
FRONTEND_URL=http://localhost:5173
